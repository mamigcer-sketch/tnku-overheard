generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id         String    @id @default(cuid())
  type       String
  content    String
  status     String    @default("PENDING")
  likes      Int       @default(0)
  views      Int       @default(0)
  location   String?
  people     String?
  gender     String?
  time       String?
  authorUuid String?   // Kullanıcının sabit post yazarı kimliği
  createdAt  DateTime  @default(now())
  comments   Comment[]
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())
  postId    String
  authorId  String?   // Aynı kişinin yorumlarını eşleştirmek için eklendi
  
  // 🔥 YENİ: Instagram tarzı yanıt (thread) sistemi için ebeveyn bağlantısı
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BannedUser {
  id        String   @id @default(cuid())
  userUuid  String   @unique
  createdAt DateTime @default(now())
}