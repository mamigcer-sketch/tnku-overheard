generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id         String    @id @default(cuid())
  type       String
  content    String?   // 🔥 DEĞİŞTİRİLDİ: Sadece ses atılabilmesi için opsiyonel (?) yapıldı
  status     String    @default("PENDING")
  likes      Int       @default(0)
  views      Int       @default(0)
  location   String?
  people     String?
  gender     String?
  time       String?
  authorUuid String?   
  
  audioUrl   String?   // 🔥 YENİ EKLENDİ: Ses dosyasının linkini tutacak

  // 🔥 24 saat sonra kaybolacak süreli postlar için bitiş zamanı
  expiresAt  DateTime? 

  createdAt  DateTime  @default(now())
  
  comments      Comment[]
  reports       Report[]  
  notifications Notification[]
}

model Comment {
  id           String        @id @default(cuid())
  content      String
  createdAt    DateTime      @default(now())
  postId       String
  authorId     String?   
  likes        Int           @default(0)  
  
  parentId     String?
  parent       Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]     @relation("CommentReplies")

  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  reactions    CommentReaction[]
  commentLikes CommentLike[]  
  reports      Report[]     
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userUuid  String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userUuid])
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BannedUser {
  id        String   @id @default(cuid())
  userUuid  String   @unique
  createdAt DateTime @default(now())
}

model Report {
  id        String   @id @default(cuid())
  reason    String   
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userUuid  String   
  message   String   
  postId    String   
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Countdown {
  id         String   @id @default(cuid())
  title      String
  targetDate DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model CustomNickname {
  id        String   @id @default(cuid())
  userUuid  String   @unique
  nickname  String
  createdAt DateTime @default(now())
}

model UserBadge {
  id        String   @id @default(cuid())
  userUuid  String   @unique
  badgeName String
  createdAt DateTime @default(now())
}

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  emoji     String   
  userUuid  String   
  createdAt DateTime @default(now())

  // Bir kişi aynı yoruma aynı emojiyi sadece 1 kez atabilsin diye:
  @@unique([commentId, userUuid, emoji])
}