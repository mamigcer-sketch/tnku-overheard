generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id         String    @id @default(cuid())
  type       String
  content    String
  status     String    @default("PENDING")
  likes      Int       @default(0)
  views      Int       @default(0)
  location   String?
  people     String?
  gender     String?
  time       String?
  authorUuid String?   
  createdAt  DateTime  @default(now())
  
  comments   Comment[]
  reports    Report[]  // 🔥 YENİ: Posta gelen şikayetler
}

model Comment {
  id           String        @id @default(cuid())
  content      String
  createdAt    DateTime      @default(now())
  postId       String
  authorId     String?   
  likes        Int           @default(0) 
  
  parentId     String?
  parent       Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]     @relation("CommentReplies")

  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentLikes CommentLike[] 
  reports      Report[]      // 🔥 YENİ: Yoruma gelen şikayetler
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userUuid  String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userUuid])
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BannedUser {
  id        String   @id @default(cuid())
  userUuid  String   @unique
  createdAt DateTime @default(now())
}

// 🔥 YENİ TABLO: Şikayetler (Admin Paneline Düşecek)
model Report {
  id        String   @id @default(cuid())
  reason    String   // Şikayet Sebebi (Küfür, Spam vs)
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}